# ==========================================
# Copie este arquivo para .env e preencha
# ==========================================

# Banco de Dados (escolha uma das opções abaixo)
# Opção 1 – URL completa
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/DATABASE

# Opção 2 – variáveis separadas (usadas se DATABASE_URL não estiver definida)
# PGHOST=
# PGUSER=
# PGPASSWORD=
# PGDATABASE=
# PGPORT=5432

# Segurança JWT — gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_PARA_UMA_STRING_ALEATORIA_SEGURA

# CORS — domínios permitidos separados por vírgula (deixe vazio para localhost apenas)
# ALLOWED_ORIGINS=https://meudominio.com,https://app.meudominio.com
ALLOWED_ORIGINS=

# Configurações da aplicação
DEBUG=False

# Limite de upload geoespacial em MB (padrão: 50)
MAX_GEOSPATIAL_FILE_MB=50

# GeoServer (opcional)
GEOSERVER_URL=https://SEU_GEOSERVER/geoserver/
GEOSERVER_WORKSPACE=pmascc
GEOSERVER_ILHAS_LAYER=ilhas
GEOSERVER_PONTOS_LAYER=vw_espacos_amostrais_geo
GEOSERVER_PUBLIC_WMS_URL=https://SEU_GEOSERVER/geoserver/wms
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=TROQUE_A_SENHA_DO_GEOSERVER
